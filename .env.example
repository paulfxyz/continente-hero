# .env.example — copy to .env and fill in your credentials
#
# cp .env.example .env
#
# .env is listed in .gitignore and will never be committed to git.
# These credentials are only used if no saved session (session/cookies.json)
# is found. The recommended flow is --save-session (see INSTALL.md).

CONTINENTE_USER=your@email.com
CONTINENTE_PASS=yourpassword
